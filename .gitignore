# =========================
# Xcode / Swift / macOS .gitignore
# Team of 4 — Xcode 15.4, 16.1, 26.5, 26.6
# =========================

## macOS
**/.DS_Store
.AppleDouble
.LSOverride
Icon?

## Xcode - user-specific state (never share, avoids merge conflicts across teammates/Xcode versions)
xcuserdata/
*.xcuserstate
*.xcuserdatad/
*.xcscmblueprint
*.xccheckout

## Xcode - build products & indexing
build/
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

## Xcode - workspace / project settings that are machine- or version-specific
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/

# Only ignore xcworkspace if it's autogenerated by CocoaPods / SPM.
# If your .xcworkspace is manually maintained and committed, remove the next line.
# *.xcworkspace

## Swift Package Manager
.build/
.swiftpm/

## Carthage (uncomment if used)
# Carthage/Build/
# Carthage/Checkouts/

## Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

## CodeCoverage / Test results
*.xcresult
*.gcda
*.gcno
TestResults/

## Playgrounds
timeline.xctimeline
playground.xcworkspace

## Compiled / obj-c generated files
*.moved-aside
*.o
*.pbxuser

## Provisioning / signing (never commit secrets)
*.mobileprovision
*.p12
*.cer

## Environment / secrets
*.env
Secrets.swift
Config/Secrets.xcconfig

## Crashlytics / Firebase (uncomment if applicable)
# GoogleService-Info.plist

## Misc editor files (in case teammates use VSCode/AppCode alongside Xcode)
.vscode/
.idea/
*.swp
*~.nib
